# ==========================================
# Manga AI Translation Web App - Environment Config
# ==========================================

# --- Application Settings ---
APP_NAME="Manga AI Translation API"
APP_ENV="local"
DEBUG=true
API_V1_STR="/api/v1"

# --- Security & Super Admin Auth ---
# Never hardcode secrets in code! Generate a secure random string for SECRET_KEY.
SECRET_KEY="your-super-secret-key-change-this-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours
SUPER_ADMIN_EMAIL="admin@manhwabkk.local"
SUPER_ADMIN_PASSWORD="supersecurepassword123!"

# --- Database (SQLite Local MVP / PostgreSQL VPS) ---
# SQLite format: sqlite+aiosqlite:///./manga_app.db
# PostgreSQL format: postgresql+asyncpg://user:password@localhost:5432/manga_db
DATABASE_URL="sqlite+aiosqlite:///./manga_app.db"

# --- Cloudflare R2 Storage (S3-Compatible) ---
# Obtain from Cloudflare Dashboard -> R2 -> Manage API Tokens
R2_ACCOUNT_ID="your_cloudflare_account_id_here"
R2_ACCESS_KEY_ID="your_r2_access_key_id_here"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key_here"
R2_BUCKET_NAME="manga-thai-storage"
# R2.dev public subdomain or custom domain (e.g., https://pub-xxxxxxxx.r2.dev)
R2_DEV_URL="https://pub-your-bucket-id.r2.dev"

# --- AI Translation Engine (Groq API) ---
# Obtain from https://console.groq.com/keys
GROQ_API_KEY="gsk_your_groq_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"

# --- DeepSeek API ---
# Obtain from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-your-deepseek-api-key-here"
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/chat/completions"
DEEPSEEK_BATCH_PAGES=5
DEEPSEEK_MAX_BATCH_SEGMENTS=80
DEEPSEEK_MAX_BATCH_INPUT_CHARS=120000
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_MAX_RETRIES=2
